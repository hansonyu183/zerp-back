APP_ENV=development
HTTP_ADDRESS=:8080
API_PORT=8080
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:4173,http://localhost:4173

POSTGRES_DB=zerp
POSTGRES_USER=zerp
POSTGRES_PASSWORD=replace-with-local-password
POSTGRES_PORT=5432
DATABASE_URL=postgres://zerp:replace-with-local-password@localhost:5432/zerp?sslmode=disable
TEST_POSTGRES_DB=zerp_test
TEST_DATABASE_URL=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:${POSTGRES_PORT}/${TEST_POSTGRES_DB}?sslmode=disable

PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_PORT=5050
PGADMIN_PASSWORD_FILE=/absolute/path/to/pgadmin-password
PGADMIN_PGPASS_FILE=/absolute/path/to/pgadmin-pgpass

DATABASE_CONNECT_TIMEOUT=5s
DATABASE_HEALTH_TIMEOUT=2s
HTTP_READ_HEADER_TIMEOUT=5s
SHUTDOWN_TIMEOUT=10s
APP_SESSION_COOKIE_NAME=zerp_session
APP_SESSION_COOKIE_SECURE=true
APP_SESSION_COOKIE_SAME_SITE=lax
APP_SESSION_IDLE_TIMEOUT=30m
APP_SESSION_ABSOLUTE_TIMEOUT=12h
APP_SIGNIN_LOCK_THRESHOLD=5
APP_SIGNIN_LOCK_DURATION=15m
APP_PASSWORD_MIN_LENGTH=12
