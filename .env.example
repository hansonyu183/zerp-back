APP_ENV=development
HTTP_ADDRESS=:8080
API_PORT=8080
CORS_ALLOWED_ORIGINS=http://localhost:5173

POSTGRES_DB=zerp
POSTGRES_USER=zerp
POSTGRES_PASSWORD=replace-with-local-password
POSTGRES_PORT=5432
DATABASE_URL=postgres://zerp:replace-with-local-password@localhost:5432/zerp?sslmode=disable

DATABASE_CONNECT_TIMEOUT=5s
DATABASE_HEALTH_TIMEOUT=2s
HTTP_READ_HEADER_TIMEOUT=5s
SHUTDOWN_TIMEOUT=10s
